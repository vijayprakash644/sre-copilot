# ── Deployment mode ─────────────────────────────────────
# Options: api | bedrock | ollama
DEPLOYMENT_MODE=api

# ── Anthropic API (Mode: api) ────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6-20250514-1

# ── AWS Bedrock (Mode: bedrock) ──────────────────────────
# Region: us-east-1 for US, ap-northeast-1 for Japan/APPI
AWS_REGION=ap-northeast-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=                    # only if using temp credentials
BEDROCK_MODEL=anthropic.claude-sonnet-4-6-20250514-v1:0

# ── Ollama (Mode: ollama) ────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# ── Slack ────────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=...
SLACK_APP_TOKEN=xapp-...             # for Socket Mode (optional)
INCIDENTS_CHANNEL=#incidents

# ── PagerDuty ────────────────────────────────────────────
PAGERDUTY_WEBHOOK_SECRET=...         # for HMAC validation

# ── Datadog (optional log context) ───────────────────────
DATADOG_API_KEY=
DATADOG_APP_KEY=
DATADOG_SITE=datadoghq.com

# ── AWS CloudWatch (optional log context) ────────────────
CLOUDWATCH_LOG_GROUP=
CLOUDWATCH_LOG_STREAM=

# ── Storage ──────────────────────────────────────────────
CHROMA_PERSIST_DIR=./data/chroma
DATABASE_URL=./data/sre_copilot.db
DATA_DIR=./data

# ── API security ─────────────────────────────────────────
API_SECRET_KEY=...                   # for /runbooks/upload + /api/* auth
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# ── App ──────────────────────────────────────────────────
APP_NAME=SRE Copilot
APP_ENV=development                  # development | production
LOG_LEVEL=INFO
MAX_LOG_LINES=20                     # max log lines sent to Claude
MAX_RUNBOOK_CHUNKS=3                 # top-K runbook chunks retrieved
MAX_PAST_INCIDENTS=2                 # top-K similar past incidents
TRIAGE_TIMEOUT_SECONDS=15
